# =============================================================================
# ServiceNow Developer Instance — Connection Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in YOUR values below
# 3. NEVER commit .env — it is in .gitignore
# =============================================================================

# Your ServiceNow Personal Developer Instance (PDI) URL
# Format: https://<your-instance>.service-now.com
SN_INSTANCE_URL=https://dev00000.service-now.com

# Basic Auth credentials (use a non-admin service account for learning)
SN_USERNAME=admin
SN_PASSWORD=your-password-here

# OAuth (alternative to basic auth — preferred for production apps)
SN_CLIENT_ID=your-oauth-client-id
SN_CLIENT_SECRET=your-oauth-client-secret

# App scope (set once per project, matches your app's scope prefix)
SN_APP_SCOPE=x_learn_dsl
