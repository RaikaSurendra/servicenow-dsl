# MVP: Container Vulnerability Management — Instance Connection
# Copy to .env and fill in your ServiceNow PDI values.
# NEVER commit .env to source control.

# ServiceNow PDI connection
SN_INSTANCE_URL=https://dev00000.service-now.com
SN_USERNAME=admin
SN_PASSWORD=your-password-here

# App scope for this project
SN_APP_SCOPE=x_vuln_container

# Optional: OAuth instead of basic auth
# SN_CLIENT_ID=your-oauth-client-id
# SN_CLIENT_SECRET=your-oauth-client-secret

# Seed data options (for local dev only)
SEED_DRY_RUN=true
SEED_CONTAINER_COUNT=10
SEED_CVE_PER_CONTAINER=5
